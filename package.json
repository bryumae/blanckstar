{
  "name": "blanckstar",
  "private": true,
  "version": "0.0.0",
  "description": "A true-scale, no-map spacecraft navigation simulator. Browser-based, Vite + TypeScript + Three.js, no backend.",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:e2e": "playwright test",
    "generate:ephemeris": "tsx scripts/generateEphemeris.ts",
    "generate:stars": "tsx scripts/generateStarCatalog.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/three": "^0.180.0",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
